---
layout: base.njk
title: Chronologie
bodyClass: page-chronologie
---

<div class="page-header">
  <h1>Chronologie</h1>
  <p>{{ site.post_count }} billets · {{ site.first_post }} → {{ site.last_post }}</p>
</div>

<div class="chrono-filters">
  <div class="filter-row">
    <label>Étape :</label>
    <div class="filter-group" id="filter-etapes">
      <button class="filter-btn active" data-etape="">Tout</button>
      <button class="filter-btn" data-etape="disponibilite-et-annee-sabbatique">Préparatifs</button>
      <button class="filter-btn" data-etape="mediterranee-les-premiers-pas-de-gregal">Méditerranée</button>
      <button class="filter-btn" data-etape="atlantique">Atlantique</button>
      <button class="filter-btn" data-etape="transat-aller-cap-vert-la-barbade">Transat aller</button>
      <button class="filter-btn" data-etape="escales-et-terres-nouvelles">Caraïbes</button>
      <button class="filter-btn" data-etape="transat-retour-st-martin-bermudes-acores-gibraltar">Transat retour</button>
      <button class="filter-btn" data-etape="retour-a-sete">Retour à Sète</button>
    </div>
  </div>

  <div class="filter-row filter-row-secondary">
    <button class="filter-btn toggle" id="filter-video">🎬 Avec vidéo</button>
    <input type="search" id="search-input" placeholder="Rechercher un titre…" aria-label="Rechercher un billet">
  </div>
</div>

<ol class="timeline" id="timeline-list">
{% set currentYear = "" %}
{% set currentMonth = "" %}
{% for post in collections.posts %}
  {% set postYear = post.published | year %}
  {% set postMonth = post.published | monthYear %}

  {% if postYear != currentYear %}
    {% if currentYear != "" %}</ul></li>{% endif %}
    <li class="timeline-year" data-year="{{ postYear }}">
      <h2 class="year-label">{{ postYear }}</h2>
      <ul class="year-posts">
    {% set currentYear = postYear %}
    {% set currentMonth = "" %}
  {% endif %}

  {% if postMonth != currentMonth %}
    {% if currentMonth != "" %}</ul></li>{% endif %}
    <li class="timeline-month">
      <h3 class="month-label">{{ postMonth }}</h3>
      <ul class="month-posts">
    {% set currentMonth = postMonth %}
  {% endif %}

  <li class="timeline-post"
      data-title="{{ post.title | lower }}"
      data-etape="{{ postEtapes[post.slug] }}"
      data-author="{{ post.author }}"
      data-has-video="{{ 'true' if '<video' in post.content else 'false' }}">
    <article class="timeline-card">
      <div class="tl-thumb-col">
        {% if postThumbnails[post.slug] %}
        <img class="tl-thumb" src="{{ postThumbnails[post.slug] | replace('/photos/', '/thumbs/') }}" alt="" loading="lazy" width="320" height="240">
        {% endif %}
      </div>
      <time datetime="{{ post.published | dateISO }}" class="post-date">
        {{ post.published | dateDisplay }}
      </time>
      <div class="timeline-card-body">
        <h4><a href="{{ ('/' + post.slug + '/') | url }}">{{ post.title }}</a></h4>
        <div class="timeline-meta">
          <span class="tl-author">{{ post.author }}</span>
          {% if post.categories.length %}
          <span class="tl-cats">
            {% for cat in post.categories %}
              <a href="{{ ('/etapes/' + (cat | slugify) + '/') | url }}" class="category-tag small">{{ cat }}</a>
            {% endfor %}
          </span>
          {% endif %}
          {% if post.gps %}<span class="tl-gps" title="Position GPS">📍</span>{% endif %}
          {% if post.comment_count > 0 %}
          <span class="tl-comments">💬 {{ post.comment_count }}</span>
          {% endif %}
        </div>
        <p class="tl-excerpt">{{ post.content | excerpt(180) }}</p>
      </div>
    </article>
  </li>

{% endfor %}
</ul></li></ul></li>
</ol>

<script>
(function () {
  const searchInput = document.getElementById('search-input');
  const etapeBtns   = document.querySelectorAll('#filter-etapes .filter-btn');
  const videBtn     = document.getElementById('filter-video');
  const posts       = document.querySelectorAll('.timeline-post');
  const yearItems   = document.querySelectorAll('.timeline-year');

  let activeEtape  = '';
  let activeVideo  = false;

  function applyFilters() {
    const query = searchInput.value.toLowerCase().trim();

    posts.forEach(post => {
      const ok =
        (!query        || post.dataset.title.includes(query)) &&
        (!activeEtape  || post.dataset.etape  === activeEtape) &&
        (!activeVideo  || post.dataset.hasVideo === 'true');
      post.style.display = ok ? '' : 'none';
    });

    yearItems.forEach(yearEl => {
      const visible = [...yearEl.querySelectorAll('.timeline-post')]
        .some(p => p.style.display !== 'none');
      yearEl.style.display = visible ? '' : 'none';
    });
  }

  // Étape buttons (radio)
  etapeBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      etapeBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeEtape = btn.dataset.etape;
      applyFilters();
    });
  });

  // Video toggle
  videBtn.addEventListener('click', () => {
    activeVideo = !activeVideo;
    videBtn.classList.toggle('active', activeVideo);
    applyFilters();
  });

  searchInput.addEventListener('input', applyFilters);
})();
</script>
