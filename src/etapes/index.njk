---
layout: base.njk
title: Étapes du voyage
bodyClass: page-etapes
---

<div class="page-header">
  <h1>Les étapes du voyage</h1>
  <p>{{ categories.length }} régions · {{ site.post_count }} billets</p>
</div>

<div class="etapes-grid">
{% for cat in categories %}
<article class="etape-card">
  <a href="{{ ('/etapes/' + cat.slug + '/') | url }}" class="etape-card-link">
    <h2 class="etape-name">{{ cat.name }}</h2>
    <div class="etape-meta">
      <span class="etape-count">{{ cat.post_count }} billet{% if cat.post_count > 1 %}s{% endif %}</span>
    </div>
  </a>
</article>
{% endfor %}
</div>
