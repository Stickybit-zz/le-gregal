---
pagination:
  data: posts
  size: 1
  alias: post
permalink: "/{{ post.slug }}/index.html"
layout: base.njk
leaflet: true
bodyClass: page-post
eleventyComputed:
  title: "{{ post.title }}"
---

<article class="post-article">

  <header class="post-header">
    {% if post.categories.length %}
    <div class="post-meta-top">
      <div class="post-categories">
        {% for cat in post.categories %}
          <a href="{{ ('/etapes/' + (cat | slugify) + '/') | url }}" class="category-tag">{{ cat }}</a>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    <h1 class="post-title">{{ post.title }}</h1>

    <div class="post-meta">
      <time datetime="{{ post.published | dateISO }}">{{ post.published | dateDisplay }}</time>
      <span class="post-author">par {{ post.author }}</span>
      {% if post.comment_count > 0 %}
      <a href="#commentaires" class="post-comment-count">
        {{ post.comment_count }} commentaire{% if post.comment_count > 1 %}s{% endif %}
      </a>
      {% endif %}
    </div>

    {% if post.gps %}
    <div class="post-gps">
      <span class="gps-icon">📍</span>
      <span class="gps-coords">{{ post.gps.lat | round(4) }}°, {{ post.gps.lon | round(4) }}°</span>
    </div>
    {% endif %}
  </header>

  {% if post.gps %}
  <div class="post-map-container">
    <div id="post-map" class="post-map"
      data-lat="{{ post.gps.lat }}"
      data-lon="{{ post.gps.lon }}"
      data-title="{{ post.title | replace('"', '&quot;') }}">
    </div>
  </div>
  {% endif %}

  <div class="post-content">
    {{ post.content | safe }}
  </div>

  <nav class="post-nav">
    {% if pagination.previousPageHref %}
    <a href="{{ pagination.previousPageHref | url }}" class="post-nav-prev">
      <span class="nav-label">← Précédent</span>
    </a>
    {% endif %}
    {% if pagination.nextPageHref %}
    <a href="{{ pagination.nextPageHref | url }}" class="post-nav-next">
      <span class="nav-label">Suivant →</span>
    </a>
    {% endif %}
  </nav>

</article>

{% set postComments = comments | commentsFor(post.id) %}
{% if postComments.length > 0 %}
<section class="comments-section" id="commentaires">
  <h2 class="comments-title">
    {{ postComments.length }} commentaire{% if postComments.length > 1 %}s{% endif %}
  </h2>
  <ol class="comments-list">
    {% for comment in postComments %}
    <li class="comment" id="comment-{{ comment.id }}">
      <header class="comment-header">
        <span class="comment-author">{{ comment.author if comment.author else "Anonyme" }}</span>
        <time class="comment-date" datetime="{{ comment.published | dateISO }}">
          {{ comment.published | dateDisplay }}
        </time>
      </header>
      <div class="comment-content">{{ comment.content | safe }}</div>
    </li>
    {% endfor %}
  </ol>
</section>
{% endif %}

{% set trackUrl = '/data/track.json' | url %}
<script>
(function() {
  const mapEl = document.getElementById('post-map');
  if (!mapEl) return;

  const lat = parseFloat(mapEl.dataset.lat);
  const lon = parseFloat(mapEl.dataset.lon);
  const title = mapEl.dataset.title;

  const map = L.map('post-map').setView([lat, lon], 7);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
    maxZoom: 18
  }).addTo(map);

  fetch('{{ trackUrl }}')
    .then(r => r.json())
    .then(track => {
      L.polyline(track.map(p => [p.lat, p.lon]), {
        color: '#2c7bb6', weight: 2, opacity: 0.45
      }).addTo(map);
    });

  const icon = L.divIcon({
    className: 'map-marker-post',
    html: '<div class="marker-dot" style="width:14px;height:14px;background:#c0392b;border-color:#fff;border-width:3px"></div>',
    iconSize: [14, 14], iconAnchor: [7, 7],
  });
  L.marker([lat, lon], { icon })
    .bindPopup(`<strong>${title}</strong>`)
    .addTo(map)
    .openPopup();
})();
</script>
