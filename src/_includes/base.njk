<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {% endif %}Le Grégal</title>
  <meta name="description" content="{% if description %}{{ description }}{% else %}Carnet de bord de Tom &amp; Aude — Méditerranée, Atlantique, Antilles, 2008-2009{% endif %}">
  <link rel="canonical" href="{{ canonicalUrl if canonicalUrl else (site.url ~ page.url) }}">
  <link rel="alternate" type="application/rss+xml" title="{{ site.title }}" href="{{ site.url }}/feed.xml">
  <meta property="og:type" content="{{ 'article' if pageType == 'article' else 'website' }}">
  <meta property="og:title" content="{% if title %}{{ title | escape }} — {% endif %}Le Grégal">
  <meta property="og:description" content="{{ (description or site.description) | escape }}">
  <meta property="og:url" content="{{ canonicalUrl if canonicalUrl else (site.url ~ page.url) }}">
  <meta property="og:image" content="{{ site.url }}{{ ogImage if ogImage else '/photos/le-gregal.jpg' }}">
  <meta property="og:site_name" content="Le Grégal">
  <meta property="og:locale" content="fr_FR">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{% if title %}{{ title | escape }} — {% endif %}Le Grégal">
  <meta name="twitter:description" content="{{ (description or site.description) | escape }}">
  <meta name="twitter:image" content="{{ site.url }}{{ ogImage if ogImage else '/photos/le-gregal.jpg' }}">
  {% if pageType == 'article' %}<script type="application/ld+json">{"@context":"https://schema.org","@type":"BlogPosting","headline":{{ title | tojson | safe }},"datePublished":{{ articleDate | tojson | safe }},"author":{"@type":"Person","name":{{ articleAuthor | tojson | safe }}},"description":{{ (description or '') | tojson | safe }},"image":{{ (site.url ~ (ogImage if ogImage else '/photos/le-gregal.jpg')) | tojson | safe }},"url":{{ (canonicalUrl if canonicalUrl else (site.url ~ page.url)) | tojson | safe }}}</script>
  {% else %}<script type="application/ld+json">{"@context":"https://schema.org","@type":"WebSite","name":"Le Grégal","description":{{ site.description | tojson | safe }},"url":{{ site.url | tojson | safe }}}</script>
  {% endif %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400&display=swap">
  <link rel="stylesheet" href="{{ '/css/style.css' | url }}">
  {% if leaflet %}
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
  {% endif %}
  <link rel="icon" href="{{ '/photos/le-gregal.jpg' | url }}" type="image/jpeg">
</head>
<body class="{{ bodyClass }}">

  <header class="site-header">
    <div class="header-inner">
      <a href="{{ '/' | url }}" class="site-logo">
        <svg class="logo-anchor" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 28" fill="currentColor" aria-hidden="true">
          <path d="M10 1 L10 22 L22 22 Z"/>
          <path d="M10 5 L2 21 L10 21 Z" opacity=".65"/>
          <rect x="9.2" y="0" width="1.6" height="23" rx=".6"/>
          <path d="M2 23 Q12 27 22 23 L21 22 L3 22 Z"/>
        </svg>
        <span class="logo-text">Le Grégal</span>
      </a>
      <nav class="site-nav">
        <a href="{{ '/' | url }}">Carte</a>
        <a href="{{ '/chronologie/' | url }}">Chronologie</a>
        <a href="{{ '/etapes/' | url }}">Explorer</a>
        <a href="{{ '/itineraire/' | url }}">Itinéraire</a>
        <a href="{{ '/album/' | url }}">Album</a>
        <a href="{{ '/a-propos/' | url }}">À propos</a>
      </nav>
      <button class="nav-toggle" aria-label="Menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  {% if leaflet %}
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  {% endif %}

  <main>
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <p>Tom &amp; Aude à bord du <em>Grégal</em> — 2008/2009</p>
      <p class="footer-stats">{{ site.post_count }} billets · {{ site.first_post }} → {{ site.last_post }}</p>
    </div>
  </footer>

  <script src="{{ '/js/nav.js' | url }}"></script>
  {% block scripts %}{% endblock %}
  <script data-goatcounter="https://le-gregal.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
</body>
</html>
