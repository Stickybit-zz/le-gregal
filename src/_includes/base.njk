<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {% endif %}Le Grégal</title>
  <meta name="description" content="{% if description %}{{ description }}{% else %}Carnet de bord de Tom &amp; Aude — Méditerranée, Atlantique, Antilles, 2008-2009{% endif %}">
  <link rel="stylesheet" href="{{ '/css/style.css' | url }}">
  {% if leaflet %}
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
  {% endif %}
  <link rel="icon" href="{{ '/photos/le-gregal.jpg' | url }}" type="image/jpeg">
</head>
<body class="{{ bodyClass }}">

  <header class="site-header">
    <div class="header-inner">
      <a href="{{ '/' | url }}" class="site-logo">
        <span class="logo-anchor">⚓</span>
        <span class="logo-text">Le Grégal</span>
      </a>
      <nav class="site-nav">
        <a href="{{ '/' | url }}">Carte</a>
        <a href="{{ '/chronologie/' | url }}">Chronologie</a>
        <a href="{{ '/etapes/' | url }}">Étapes</a>
        <a href="{{ '/a-propos/' | url }}">À propos</a>
      </nav>
      <button class="nav-toggle" aria-label="Menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  {% if leaflet %}
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  {% endif %}

  <main>
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <p>Tom &amp; Aude à bord du <em>Grégal</em> — 2008/2009</p>
      <p class="footer-stats">{{ site.post_count }} billets · {{ site.first_post }} → {{ site.last_post }}</p>
    </div>
  </footer>

  <script>
  document.querySelector('.nav-toggle').addEventListener('click', function() {
    const nav = document.querySelector('.site-nav');
    const expanded = this.getAttribute('aria-expanded') === 'true';
    this.setAttribute('aria-expanded', !expanded);
    nav.classList.toggle('open');
  });
  </script>

  {% block scripts %}{% endblock %}
</body>
</html>
