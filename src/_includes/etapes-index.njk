<div class="page-header">
  <h1>Les étapes du voyage</h1>
  <p>{{ etapesList | length }} régions · {{ site.post_count }} billets</p>
</div>

<div id="etapes-map" class="global-map"></div>

<div class="etapes-grid">
{% for etape in etapesList %}
<article class="etape-card">
  <a href="/etapes/{{ etape.slug }}/" class="etape-card-link">
    <h2 class="etape-name">{{ etape.name }}</h2>
    <div class="etape-meta">
      <span class="etape-count">{{ etape.post_count }} billet{% if etape.post_count > 1 %}s{% endif %}</span>
      <span class="etape-date">{{ etape.first_post }}</span>
    </div>
  </a>
</article>
{% endfor %}
</div>

<script>
(function() {
  const map = L.map('etapes-map', { scrollWheelZoom: false }).setView([25, -30], 3);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
    maxZoom: 18
  }).addTo(map);

  fetch('/data/track.json')
    .then(r => r.json())
    .then(track => {
      if (!track.length) return;
      L.polyline(track.map(p => [p.lat, p.lon]), {
        color: '#2c7bb6', weight: 3, opacity: 0.8
      }).addTo(map);
      map.fitBounds(L.latLngBounds(track.map(p => [p.lat, p.lon])).pad(0.1));
    });
})();
</script>
