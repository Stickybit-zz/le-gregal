---
layout: base.njk
title: "Carnet de bord d'un tour de l'Atlantique en voilier"
description: "Année sabbatique en voilier : Tom & Aude quittent Sète pour un tour de l'Atlantique à bord du Grégal, un Contention 33. Méditerranée, Canaries, Cap-Vert, transat, Antilles, Açores."
leaflet: true
bodyClass: page-home
---

<section class="hero">
  <video class="hero-video" autoplay muted loop playsinline
    poster="{{ '/photos/hero-poster.jpg' | url }}"
    aria-hidden="true">
    <source src="{{ '/videos/hero.mp4' | url }}" type="video/mp4">
  </video>
  <div class="hero-overlay"></div>
  <div class="hero-text">
    <h1>Le Grégal</h1>
    <p class="hero-subtitle">Une année sabbatique en voilier — 2008 / 2009</p>
    <p class="hero-description">
      Tom &amp; Aude quittent Sète le 2 août 2008 à bord du Grégal, un Contention 33 de 9,98 m.
      Méditerranée, Atlantique, Antilles… et retour à Sète, 12 mois après le départ.
    </p>
    <div class="hero-stats">
      <span>{{ site.post_count }} billets</span>
      <span>18 escales</span>
      <span>{{ site.first_post | truncate(7, false, "") }} → {{ site.last_post | truncate(7, false, "") }}</span>
    </div>
  </div>
</section>

<div id="global-map" class="global-map"></div>

<section class="voyage-stages">
  <h2>Le voyage en 7 étapes</h2>
  <div class="stages-grid">
    <a href="{{ '/etapes/disponibilite-et-annee-sabbatique/' | url }}" class="stage-card">
      <div class="stage-img"><img src="{{ '/thumbs/album/08-02-16_Bapteme_du_Gregal_24.JPG' | url }}" alt="Baptême du Grégal, 2008" loading="lazy"></div>
      <div class="stage-card-body">
        <h3>Préparatifs</h3>
        <p>Quitter son travail, acheter un voilier d'occasion, apprendre à naviguer</p>
        <span class="stage-count">{{ (categories | catBySlug("disponibilite-et-annee-sabbatique")).post_count }} billets</span>
      </div>
    </a>
    <a href="{{ '/etapes/mediterranee-les-premiers-pas-de-gregal/' | url }}" class="stage-card">
      <div class="stage-img"><img src="{{ '/thumbs/album/budelli2.jpg' | url }}" alt="Plage de Budelli, Sardaigne" loading="lazy"></div>
      <div class="stage-card-body">
        <h3>Méditerranée</h3>
        <p>Sète, Corse, Sardaigne, Baléares, Espagne</p>
        <span class="stage-count">{{ (categories | catBySlug("mediterranee-les-premiers-pas-de-gregal")).post_count }} billets</span>
      </div>
    </a>
    <a href="{{ '/etapes/atlantique/' | url }}" class="stage-card">
      <div class="stage-img"><img src="{{ '/thumbs/album/DSC_0002.jpg' | url }}" alt="Navigation vers les Canaries" loading="lazy"></div>
      <div class="stage-card-body">
        <h3>Atlantique</h3>
        <p>Gibraltar, Maroc, Canaries, Cap Vert</p>
        <span class="stage-count">{{ (categories | catBySlug("atlantique")).post_count }} billets</span>
      </div>
    </a>
    <a href="{{ '/etapes/transat-aller-cap-vert-la-barbade/' | url }}" class="stage-card">
      <div class="stage-img"><img src="{{ '/thumbs/album/DSC_0594.JPG' | url }}" alt="En mer, traversée Cap Vert — Barbade" loading="lazy"></div>
      <div class="stage-card-body">
        <h3>Transat aller</h3>
        <p>18 jours en mer, 2 600 milles, Cap Vert → Barbade</p>
        <span class="stage-count">{{ (categories | catBySlug("transat-aller-cap-vert-la-barbade")).post_count }} billets</span>
      </div>
    </a>
    <a href="{{ '/etapes/escales-et-terres-nouvelles/' | url }}" class="stage-card">
      <div class="stage-img"><img src="{{ '/thumbs/album/view_baradel2.jpg' | url }}" alt="Île de Baradel, Grenadines" loading="lazy"></div>
      <div class="stage-card-body">
        <h3>Caraïbes</h3>
        <p>Barbade, Martinique, Guadeloupe, Grenade, Grenadines, Antigua…</p>
        <span class="stage-count">{{ (categories | catBySlug("escales-et-terres-nouvelles")).post_count }} billets</span>
      </div>
    </a>
    <a href="{{ '/etapes/transat-retour-st-martin-bermudes-acores-gibraltar/' | url }}" class="stage-card">
      <div class="stage-img"><img src="{{ '/thumbs/album/DSC05824.JPG' | url }}" alt="Départ de Saint-Martin, transat retour" loading="lazy"></div>
      <div class="stage-card-body">
        <h3>Transat retour</h3>
        <p>Saint-Martin, Bermudes, Açores, Gibraltar</p>
        <span class="stage-count">{{ (categories | catBySlug("transat-retour-st-martin-bermudes-acores-gibraltar")).post_count }} billets</span>
      </div>
    </a>
    <a href="{{ '/etapes/retour-a-sete/' | url }}" class="stage-card">
      <div class="stage-img"><img src="{{ '/thumbs/album/yawl.jpg' | url }}" alt="Yawl au coucher de soleil, retour en Méditerranée" loading="lazy"></div>
      <div class="stage-card-body">
        <h3>Retour à Sète</h3>
        <p>Côte espagnole, Gibraltar, Méditerranée</p>
        <span class="stage-count">{{ (categories | catBySlug("retour-a-sete")).post_count }} billets</span>
      </div>
    </a>
  </div>
</section>

<section class="best-of">
  <h2>Les billets incontournables</h2>
  <p class="section-intro">Une sélection de 33 billets pour découvrir le voyage — utiles aussi pour ceux qui préparent leur propre aventure.</p>
  <div class="posts-grid">
    {% for cat in categories %}
    {% if cat.slug == 'best-of-billets-special-remembering' %}
    {% for post in cat.posts %}
    <article class="post-card">
      {% if postThumbnails[post.slug] %}
      <img class="post-card-thumb" src="{{ postThumbnails[post.slug] }}" alt="{{ post.title }}" loading="lazy">
      {% endif %}
      <div class="post-card-body">
        <div class="post-card-meta">
          <time datetime="{{ post.published | dateISO }}">{{ post.published | dateDisplay }}</time>
        </div>
        <h3><a href="{{ ('/' + post.slug + '/') | url }}">{{ post.title }}</a></h3>
        <p class="post-card-excerpt">{{ post.content | excerpt(140) }}</p>
        {% if post.gps %}<span class="post-card-gps" title="Position GPS">📍</span>{% endif %}
      </div>
    </article>
    {% endfor %}
    {% endif %}
    {% endfor %}
  </div>
  <p class="all-posts-link"><a href="{{ '/chronologie/' | url }}">Tous les {{ site.post_count }} billets →</a></p>
</section>

{% set trackUrl = '/data/track.json' | url %}
{% set routeUrl = '/data/voyage-route.json' | url %}
{% set baseUrl = '/' | url %}
<script>
(function() {
  const map = L.map('global-map', {
    zoomControl: true,
    scrollWheelZoom: false
  }).setView([25, -30], 3);

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
    maxZoom: 18
  }).addTo(map);

  map.on('click', function() { map.scrollWheelZoom.enable(); });
  map.on('blur',  function() { map.scrollWheelZoom.disable(); });

  const base = '{{ baseUrl }}';

  Promise.all([
    fetch('{{ routeUrl }}').then(r => r.json()),
    fetch('{{ trackUrl }}').then(r => r.json())
  ]).then(([route, track]) => {

    // ── Segments approximatifs (tiretés) ──────────────────────────────────
    route.segments.forEach(seg => {
      L.polyline(seg.coords, {
        color: '#2c7bb6',
        weight: 2,
        opacity: 0.45,
        dashArray: '8, 8',
        lineJoin: 'round'
      }).addTo(map);
    });

    // ── Track GPS (trait plein) ────────────────────────────────────────────
    if (track.length) {
      const coords = track.map(p => [p.lat, p.lon]);
      L.polyline(coords, {
        color: '#2c7bb6',
        weight: 3,
        opacity: 0.85,
        lineJoin: 'round'
      }).addTo(map);

      const markerIcon = L.divIcon({
        className: 'map-marker',
        html: '<div class="marker-dot"></div>',
        iconSize: [12, 12],
        iconAnchor: [6, 6],
      });

      track.forEach(point => {
        const date = new Date(point.published).toLocaleDateString('fr-FR', {
          day: 'numeric', month: 'long', year: 'numeric'
        });
        L.marker([point.lat, point.lon], { icon: markerIcon })
          .bindPopup(
            `<div class="map-popup">
              <time>${date}</time>
              <a href="${base}${point.slug}/">${point.title}</a>
            </div>`,
            { maxWidth: 220 }
          )
          .addTo(map);
      });
    }

    // ── Marqueurs d'escale ────────────────────────────────────────────────
    route.stops.forEach(stop => {
      const circle = L.circleMarker([stop.lat, stop.lon], {
        radius: 6,
        color: '#fff',
        weight: 2,
        fillColor: '#e05b2a',
        fillOpacity: 0.9
      });

      const href = stop.slug ? `${base}etapes/${stop.slug}/` : null;
      const nameHtml = href
        ? `<a href="${href}">${stop.name}</a>`
        : `<strong>${stop.name}</strong>`;
      circle.bindPopup(
        `<div class="map-popup map-popup-stop">${nameHtml}</div>`,
        { maxWidth: 200 }
      );
      circle.addTo(map);
    });

    // ── Ajuster les bounds pour tout voir ─────────────────────────────────
    const allCoords = route.segments.flatMap(s => s.coords)
      .concat(route.stops.map(s => [s.lat, s.lon]))
      .concat(track.map(p => [p.lat, p.lon]));
    map.fitBounds(L.latLngBounds(allCoords).pad(0.05));
  });
})();
</script>
