---
layout: base.njk
title: Carte du voyage
leaflet: true
bodyClass: page-home
---

<section class="hero">
  <div class="hero-text">
    <h1>Le Grégal</h1>
    <p class="hero-subtitle">Une année sabbatique en voilier — 2008 / 2009</p>
    <p class="hero-description">
      Tom &amp; Aude quittent Sète en juin 2008 à bord du Grégal, un voilier de 10,5 m.
      Méditerranée, Atlantique, Antilles… 14 mois et 14 000 milles plus tard, retour à Gibraltar.
    </p>
    <div class="hero-stats">
      <span>{{ site.post_count }} billets</span>
      <span>50 positions GPS</span>
      <span>{{ site.first_post | truncate(7, false, "") }} → {{ site.last_post | truncate(7, false, "") }}</span>
    </div>
  </div>
</section>

<div id="global-map" class="global-map"></div>

<section class="latest-posts">
  <h2>Derniers billets</h2>
  <div class="posts-grid">
    {% set allPosts = collections.posts %}
    {% for post in allPosts | reverse | slice(0, 6) %}
    <article class="post-card">
      <div class="post-card-meta">
        <time datetime="{{ post.published | dateISO }}">{{ post.published | dateDisplay }}</time>
        <span class="post-card-author">{{ post.author }}</span>
      </div>
      <h3><a href="{{ ('/' + post.slug + '/') | url }}">{{ post.title }}</a></h3>
      <p class="post-card-excerpt">{{ post.content | excerpt(160) }}</p>
      {% if post.gps %}
      <span class="post-card-gps" title="Position GPS">📍</span>
      {% endif %}
    </article>
    {% endfor %}
  </div>
  <p class="all-posts-link"><a href="{{ '/chronologie/' | url }}">Tous les {{ site.post_count }} billets →</a></p>
</section>

{% set trackUrl = '/data/track.json' | url %}
{% set baseUrl = '/' | url %}
<script>
(function() {
  const map = L.map('global-map', {
    zoomControl: true,
    scrollWheelZoom: false
  }).setView([25, -30], 3);

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
    maxZoom: 18
  }).addTo(map);

  map.on('click', function() { map.scrollWheelZoom.enable(); });
  map.on('blur',  function() { map.scrollWheelZoom.disable(); });

  fetch('{{ trackUrl }}')
    .then(r => r.json())
    .then(track => {
      if (!track.length) return;

      const coords = track.map(p => [p.lat, p.lon]);
      L.polyline(coords, {
        color: '#2c7bb6',
        weight: 3,
        opacity: 0.8,
        lineJoin: 'round'
      }).addTo(map);

      const markerIcon = L.divIcon({
        className: 'map-marker',
        html: '<div class="marker-dot"></div>',
        iconSize: [12, 12],
        iconAnchor: [6, 6],
      });

      const base = '{{ baseUrl }}';
      track.forEach(point => {
        const date = new Date(point.published).toLocaleDateString('fr-FR', {
          day: 'numeric', month: 'long', year: 'numeric'
        });
        L.marker([point.lat, point.lon], { icon: markerIcon })
          .bindPopup(
            `<div class="map-popup">
              <time>${date}</time>
              <a href="${base}${point.slug}/">${point.title}</a>
            </div>`,
            { maxWidth: 220 }
          )
          .addTo(map);
      });

      map.fitBounds(L.latLngBounds(coords).pad(0.1));
    });
})();
</script>
