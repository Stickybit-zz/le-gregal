---
pagination:
  data: categories
  size: 1
  alias: category
permalink: "/etapes/{{ category.slug }}/index.html"
layout: base.njk
bodyClass: page-etape
eleventyComputed:
  title: "{{ category.name | safe }}"
  description: "{{ category.post_count }} billets sur {{ category.name | safe }} — voyage en voilier de Tom et Aude (2008-2009)"
  canonicalUrl: "{{ site.url }}/etapes/{{ category.slug }}/"
---

<div class="page-header">
  <a href="{{ '/etapes/' | url }}" class="back-link">← Toutes les étapes</a>
  <h1>{{ category.name }}</h1>
  <p>{{ category.post_count }} billet{% if category.post_count > 1 %}s{% endif %}</p>
  {% if category.posts.length %}
  <p class="page-header-dates">{{ category.posts[0].published | dateDisplay }} → {{ category.posts[category.posts.length - 1].published | dateDisplay }}</p>
  {% endif %}
</div>

<ol class="etape-posts-list">
{% for post in category.posts %}
<li class="etape-post-item">
  <article class="timeline-card">
    <div class="tl-thumb-col">
      {% if postThumbnails[post.slug] %}
      <img class="tl-thumb" src="{{ postThumbnails[post.slug] | replace('/photos/', '/thumbs/') }}" alt="{{ post.title }}" loading="lazy" width="320" height="240">
      {% endif %}
    </div>
    <time datetime="{{ post.published | dateISO }}" class="post-date">{{ post.published | dateDisplay }}</time>
    <div class="timeline-card-body">
      <h3><a href="{{ ('/' + post.slug + '/') | url }}">{{ post.title }}</a></h3>
      <div class="timeline-meta">
        {% if post.gps %}<span class="tl-gps">📍</span>{% endif %}
      </div>
      <p class="tl-excerpt">{{ post.content | excerpt(180) }}</p>
    </div>
  </article>
</li>
{% endfor %}
</ol>

