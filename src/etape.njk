---
pagination:
  data: categories
  size: 1
  alias: category
permalink: "/etapes/{{ category.slug }}/index.html"
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ category.name }} — Le Grégal</title>
  <link rel="stylesheet" href="{{ '/css/style.css' | url }}">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="">
  <link rel="icon" href="{{ '/photos/le-gregal.jpg' | url }}" type="image/jpeg">
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <a href="{{ '/' | url }}" class="site-logo"><span class="logo-anchor">⚓</span><span class="logo-text">Le Grégal</span></a>
      <nav class="site-nav">
        <a href="{{ '/' | url }}">Carte</a>
        <a href="{{ '/chronologie/' | url }}">Chronologie</a>
        <a href="{{ '/etapes/' | url }}">Étapes</a>
        <a href="{{ '/a-propos/' | url }}">À propos</a>
      </nav>
      <button class="nav-toggle" aria-label="Menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <main>
    <div class="page-header">
      <a href="{{ '/etapes/' | url }}" class="back-link">← Toutes les étapes</a>
      <h1>{{ category.name }}</h1>
      <p>{{ category.post_count }} billet{% if category.post_count > 1 %}s{% endif %}</p>
    </div>

    {% if category.gps_center %}
    <div id="etape-map" class="etape-map"
      data-lat="{{ category.gps_center[0] }}"
      data-lon="{{ category.gps_center[1] }}">
    </div>
    {% endif %}

    <ol class="etape-posts-list">
    {% for post in category.posts %}
    <li class="etape-post-item">
      <article class="timeline-card">
        <time datetime="{{ post.published | dateISO }}" class="post-date">{{ post.published | dateDisplay }}</time>
        <div class="timeline-card-body">
          <h3><a href="{{ ('/' + post.slug + '/') | url }}">{{ post.title }}</a></h3>
          <div class="timeline-meta">
            {% if post.gps %}<span class="tl-gps">📍</span>{% endif %}
          </div>
          <p class="tl-excerpt">{{ post.content | excerpt(180) }}</p>
        </div>
      </article>
    </li>
    {% endfor %}
    </ol>
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <p>Tom &amp; Aude à bord du <em>Grégal</em> — 2008/2009</p>
    </div>
  </footer>

  <script>
  document.querySelector('.nav-toggle').addEventListener('click', function() {
    const nav = document.querySelector('.site-nav');
    const expanded = this.getAttribute('aria-expanded') === 'true';
    this.setAttribute('aria-expanded', !expanded);
    nav.classList.toggle('open');
  });
  </script>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV/XN/WLcE=" crossorigin=""></script>
  {% set trackUrl = '/data/track.json' | url %}
  <script>
  (function() {
    const mapEl = document.getElementById('etape-map');
    if (!mapEl) return;
    const lat = parseFloat(mapEl.dataset.lat);
    const lon = parseFloat(mapEl.dataset.lon);
    if (isNaN(lat) || isNaN(lon)) return;

    const map = L.map('etape-map', { scrollWheelZoom: false }).setView([lat, lon], 6);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
      maxZoom: 18
    }).addTo(map);

    fetch('{{ trackUrl }}')
      .then(r => r.json())
      .then(track => {
        L.polyline(track.map(p => [p.lat, p.lon]), {
          color: '#2c7bb6', weight: 2, opacity: 0.3
        }).addTo(map);
      });
  })();
  </script>
</body>
</html>
